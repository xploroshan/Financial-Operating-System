{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "pnpm --filter @lcos/core build && prisma generate && mkdir -p public",
  "installCommand": "pnpm install --no-frozen-lockfile",
  "outputDirectory": "public",
  "functions": {
    "api/[[...path]].ts": {
      "memory": 1024,
      "maxDuration": 30
    }
  }
}
