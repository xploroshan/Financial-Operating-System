{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "pnpm --filter @lcos/core build && prisma generate && nest build",
  "installCommand": "pnpm install --no-frozen-lockfile",
  "outputDirectory": "public",
  "functions": {
    "api/index.js": {
      "memory": 1024,
      "maxDuration": 30,
      "includeFiles": "dist/**"
    }
  },
  "rewrites": [{ "source": "/api/(.*)", "destination": "/api/index" }, { "source": "/api", "destination": "/api/index" }]
}
